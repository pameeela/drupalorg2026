{#
/**
 * @file
 * Preload the commonly used fonts for the headings and the body copy.
 *
 * Available variables:
 * - drupalorg_path: Returns the path to the Drupalorg theme.
 */
#}

<link rel="preload" href="{{ drupalorg_path }}/fonts/noto-sans/noto-sans-v42-latin-300.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="{{ drupalorg_path }}/fonts/ztgatha/ZTGatha-Bold.woff2" as="font" type="font/woff2" crossorigin />
