{% set pager_page =
  html_cva(
    base: [
      'flex h-10 min-h-10 w-10 min-w-10 shrink-0 items-center justify-center rounded',
      'text-sm font-semibold tabular-nums md:text-base',
      'transition-colors duration-300'
    ],
    variants: {
      isCurrent: {
        yes: 'bg-primary font-bold text-white',
        no: 'hover:bg-light-blue'
      }
    }
  )
%}
{% set list_classes = ['pager__items', 'js-pager__items', 'flex list-none items-center justify-center gap-1'] %}
{% set pager_nav_link_classes = 'flex items-center justify-center gap-1 py-2 rounded hover:bg-light-blue transition-colors duration-300' %}
{% set pager_icon_link_classes = 'pager__icon flex shrink-0 items-center justify-center' %}
{% set pager_icon_ellipsis_classes = 'pager__icon flex shrink-0 items-center justify-center' %}
{% set var = value %}
{% set classes = ['pager', 'my-4', 'font-medium'] %}
{% set ellipsis_container_classes = ['flex items-center justify-center rounded px-2 py-1.5'] %}

{% if items %}
  <nav class="{{ classes|join(' ') }}" role="navigation" aria-labelledby="{{ heading_id }}">
    {% if pagination_heading_level == 'h1' %}
      <h1 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h1>
    {% elseif pagination_heading_level == 'h2' %}
      <h2 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h2>
    {% elseif pagination_heading_level == 'h3' %}
      <h3 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h3>
    {% elseif pagination_heading_level == 'h4' %}
      <h4 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h4>
    {% elseif pagination_heading_level == 'h5' %}
      <h5 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h5>
    {% elseif pagination_heading_level == 'h6' %}
      <h6 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h6>
    {% else %}
      <h2 id="{{ heading_id }}" class="sr-only">{{ 'Pagination'|t }}</h2>
    {% endif %}
    <ul class="{{ list_classes|join(' ') }}">
      {# Print first item if we are not on the first page. #}
      {% if items.first %}
        <li>
          <a
            href="{{ items.first.href }}"
            title="{{ 'Go to first page'|t }}"
            {{ items.first.attributes.addClass(pager_nav_link_classes, 'ps-1 pe-2')|without('href', 'title') }}
          >
            <span class="sr-only">{{ 'First page'|t }}</span>
            <span aria-hidden="true" class="pager__list-item text-sm whitespace-nowrap md:text-base">
              <div class="flex gap-1">
                <span class="{{ pager_icon_link_classes }} translate-y-0.5" aria-hidden="true">
                  {{
                    include(
                      'mercury:icon',
                      {
                        icon: 'caret-double-left',
                        icon_size: 'extra-small'
                      }
                    )
                  }}
                </span>
              </div>
            </span>
          </a>
        </li>
      {% endif %}
      {# Print previous item if we are not on the first page. #}
      {% if items.previous %}
        <li class="pager__item pager__item--previous">
          <a
            href="{{ items.previous.href }}"
            title="{{ 'Go to previous page'|t }}"
            rel="prev"
            class="{{ pager_nav_link_classes }} ml-2 pe-1 lg:pe-2"
            {{ items.previous.attributes|without('href', 'title', 'rel') }}
          >
            <span class="sr-only">{{ 'Previous page'|t }}</span>
            <span class="{{ pager_icon_link_classes }}" aria-hidden="true">
              {{
                include(
                  'mercury:icon',
                  {
                    icon: 'caret-left',
                    icon_size: 'extra-small'
                  }
                )
              }}
            </span>
          </a>
        </li>
      {% endif %}
      {# Add an ellipsis if there are further previous pages. #}

      {% if ellipses.previous %}
        <li>
          <span class="{{ ellipsis_container_classes|join(' ') }}" role="presentation">
            <span class="{{ pager_icon_ellipsis_classes }}" aria-hidden="true">
              {{
                include(
                  'mercury:icon',
                  {
                    icon: 'dots-three',
                    icon_size: 'extra-small'
                  }
                )
              }}
            </span>
          </span>
        </li>
      {% endif %}
      {# Now generate the actual pager piece. #}
      {% for key, item in items.pages %}
        <li>
          {% set is_current_page = current == key ? 'yes' : 'no' %}
          <a
            href="{{ item.href }}"
            title="{{ title }}"
            {{ item.attributes.addClass(
              pager_page.apply({
                isCurrent: is_current_page
              })
            )|without('href', 'title') }}
          >
            <span class="sr-only">{{ 'Page'|t }}</span>
            <span class="pager__list-item text-sm whitespace-nowrap md:text-base">{{- key -}}</span>
          </a>
        </li>
      {% endfor %}
      {# Add an ellipsis if there are further next pages. #}
      {% if ellipses.next %}
        <li>
          <span class="{{ ellipsis_container_classes|join(' ') }}" role="presentation">
            <span class="{{ pager_icon_ellipsis_classes }}" aria-hidden="true">
              {{
                include(
                  'mercury:icon',
                  {
                    icon: 'dots-three',
                    icon_size: 'extra-small'
                  }
                )
              }}
            </span>
          </span>
        </li>
      {% endif %}
      {# Print next item if we are not on the last page. #}
      {% if items.next %}
        <li class="pager__item pager__item--next">
          <a
            href="{{ items.next.href }}"
            title="{{ 'Go to next page'|t }}"
            rel="next"
            class="{{ pager_nav_link_classes }} mr-2 ps-1 lg:ps-2"
            {{ items.next.attributes|without('href', 'title', 'rel') }}
          >
            <span class="sr-only">{{ 'Next page'|t }}</span>
            <span class="{{ pager_icon_link_classes }}" aria-hidden="true">
              {{
                include(
                  'mercury:icon',
                  {
                    icon: 'caret-right',
                    icon_size: 'extra-small'
                  }
                )
              }}
            </span>
          </a>
        </li>
      {% endif %}
      {# Print last item if we are not on the last page. #}
      {% if items.last %}
        <li>
          <a
            href="{{ items.last.href }}"
            title="{{ 'Go to last page'|t }}"
            {{ items.last.attributes.addClass(pager_nav_link_classes, 'pe-1 ps-2')|without('href', 'title') }}
          >
            <span class="sr-only">{{ 'Last page'|t }}</span>
            <span aria-hidden="true" class="pager__list-item text-sm whitespace-nowrap md:text-base">
              <div class="flex gap-1">
                <span class="{{ pager_icon_link_classes }} translate-y-0.5" aria-hidden="true">
                  {{
                    include(
                      'mercury:icon',
                      {
                        icon: 'caret-double-right',
                        icon_size: 'extra-small'
                      }
                    )
                  }}
                </span>
              </div>
            </span>
          </a>
        </li>
      {% endif %}
    </ul>
  </nav>
{% endif %}
