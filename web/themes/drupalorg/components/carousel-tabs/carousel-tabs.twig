{% set is_autoplay = autoplay|default(true) %}

<section class="carousel-tabs cq-full flex flex-col gap-8" data-autoplay="{{ is_autoplay ? 'true' : 'false' }}">
  {% if block('header') is defined %}
    <div class="carousel-tabs__header flex flex-col items-center gap-4 text-center [&_*]:max-w-2xl">
      {% block header %}
        {% include '@drupalorg/components/badge/badge.twig' with {
          label: 'Why Drupal CMS',
          style: 'transparent'
        } only %}
        <h2>Launch professional websites in hours, not weeks.</h2>
      {% endblock %}
    </div>
  {% endif %}

  {# Feature nav row — populated by carousel-tabs.js from each slide's nav. #}
  <div class="carousel-tabs__nav" role="group" aria-label="{{ 'Carousel features'|t }}"></div>

  <div class="swiper">
    <div class="swiper-wrapper">
      {% block slides %}
        {% embed 'drupalorg:slide'
          with {
            title: 'One-click site templates',
            icon: 'squares-four',
            description: 'Choose a template, launch, and customise. Professional sites in hours.'
          }
        %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with {
              label: 'Template Library',
              href: '#',
              variant: 'primary',
              icon: 'arrow-right'
            } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}

        {% embed 'drupalorg:slide'
          with {
            title: 'AI agents from day one',
            icon: 'sparkle',
            description: 'Content creation, SEO, translation, accessibility — built in, not bolted on.'
          }
        %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with {
              label: 'Explore AI',
              href: '#',
              variant: 'primary',
              icon: 'arrow-right'
            } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}

        {% embed 'drupalorg:slide'
          with {
            title: 'No ceiling',
            icon: 'infinity',
            description: 'The same platform trusted by NASA, UNICEF, and the European Commission. Start small, scale infinitely.'
          }
        %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with {
              label: 'See what Drupal can do',
              href: '#',
              variant: 'primary',
              icon: 'arrow-right'
            } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}
      {% endblock %}
    </div>
  </div>

  {# Mobile-only: active slide's feature info + CTAs, populated by carousel-tabs.js. #}
  <div class="carousel-tabs__detail"></div>

  {{ attach_library('drupalorg/carousel-tabs') }}
</section>
