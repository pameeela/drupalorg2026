{% set button_variant = variant|default('primary') %}
{% set is_disabled = disabled|default(false) %}
{% set has_icon = icon is not empty %}

{% set button_variants =
  html_cva(
    base: [
      'group inline-flex w-fit items-center justify-center gap-2.5',
      'rounded-full px-5 py-3 text-sm leading-normal font-medium',
      'cursor-pointer no-underline transition duration-300 ease-in-out hover:no-underline',
      'focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:outline-none',
      'disabled:pointer-events-none disabled:opacity-50'
    ],
    variants: {
      variant: {
        primary: 'bg-primary text-primary-foreground hover:bg-primary/85',
        'light-blue': 'bg-drupal-light-blue text-primary hover:bg-drupal-light-blue/85',
        'white-outline': 'border border-primary bg-white text-primary hover:bg-white/90',
        transparent: 'border border-white text-white hover:text-drupal-light-blue',
        white: 'bg-white text-primary hover:bg-white/90'
      }
    }
  )
%}

{% set icon_classes = 'transition duration-300 ease-in-out group-hover:translate-x-1' %}

{# Normalize btn_classes - handle both array and string formats #}
{% set additional_classes = btn_classes|default('') %}
{% if additional_classes is iterable %}
  {% set additional_classes = additional_classes|join(' ') %}
{% endif %}

{# If href is provided and button is not disabled, present a link; otherwise render a button #}
{% set disabled_attr = is_disabled ? 'aria-disabled="true"' : '' %}
{% set button_disabled_attr = is_disabled ? 'disabled' : '' %}
{% set href = disabled|default(false) ? null : href %}

{% if href %}
  <a
    href="{{ href }}"
    class="{{
    button_variants.apply(
      {
        variant: button_variant
      },
      additional_classes
    )
    }}"
    {{ disabled_attr }}
  >
    {{ label }}
    {% if has_icon %}
      <span class="{{ icon_classes }}">
        {{
          include(
            '@drupalorg/components/icon/icon.twig',
            {
              icon: icon,
              icon_size: 'extra-small'
            },
            with_context: false
          )
        }}
      </span>
    {% endif %}
  </a>
{% else %}
  <button
    class="{{
    button_variants.apply(
      {
        variant: button_variant
      },
      additional_classes
    )
    }}"
    {{ button_disabled_attr }}
  >
    {{ label }}
    {% if has_icon %}
      <span class="{{ icon_classes }}">
        {{
          include(
            '@drupalorg/components/icon/icon.twig',
            {
              icon: icon,
              icon_size: 'extra-small'
            },
            with_context: false
          )
        }}
      </span>
    {% endif %}
  </button>
{% endif %}
