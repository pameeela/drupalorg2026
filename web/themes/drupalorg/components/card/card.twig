{% set card_style = style|default('classic') %}
{% set heading_level = level|default(3) %}
{% set has_media = media.src is not empty %}
{% set has_text = text is not empty %}
{% set has_url = url is not empty %}
{% set has_cta = has_url and cta_text is not empty %}
{% set is_featured = card_style == 'featured' %}
{% set button_variant = is_featured ? 'transparent-white' : 'light-blue' %}

{% set card =
  html_cva(
    base: ['group relative flex flex-col overflow-clip in-[.views-row]:h-full'],
    variants: {
      style: {
        classic: 'rounded-lg bg-card text-card-foreground',
        featured: 'min-h-[480px] justify-end rounded-2xl bg-darkest-gray text-white'
      }
    }
  )
%}

{% set card_content =
  html_cva(
    base: 'pointer-events-none relative flex flex-col',
    variants: {
      style: {
        classic: 'flex-1 justify-between p-8',
        featured: 'bg-gradient-to-t from-darkest-blue via-darkest-blue/85 to-transparent p-8'
      }
    }
  )
%}

{% set card_text =
  html_cva(
    base: 'flex flex-col gap-3',
    variants: {
      hasCta: {
        yes: 'pb-8',
        no: ''
      }
    }
  )
%}

<div
  class="{{
  card.apply(
    {
      style: card_style
    },
    card_classes|default('')
  )
  }}"
>
  {% if is_featured %}
    {# Full-bleed background image with a dark gradient scrim for text legibility. #}
    {% if has_media %}
      <div class="absolute inset-0">
        {% include 'canvas:image' ignore missing with {
          src: media.src,
          alt: media.alt,
          class: 'size-full object-cover transition duration-300 ease-in-out group-hover:scale-110',
          width: media.width,
          height: media.height,
          sizes: '100vw'
        } only %}
      </div>
    {% endif %}
  {% elseif has_media %}
    {# Framed image sitting above the content. #}
    <div class="w-full px-1 pt-1">
      <div class="aspect-[1619/971] w-full overflow-hidden rounded-sm">
        {% include 'canvas:image' ignore missing with {
          src: media.src,
          alt: media.alt,
          class: 'object-cover w-full h-full transition duration-300 ease-in-out group-hover:scale-110',
          width: media.width,
          height: media.height,
          sizes: '100vw'
        } only %}
      </div>
    </div>
  {% endif %}

  {% if has_url %}
    <a href="{{ url }}" class="absolute inset-0" aria-hidden="true" tabindex="-1"></a>
  {% endif %}

  <div
    class="{{
    card_content.apply({
      style: card_style
    })
    }}"
  >
    <div
      class="{{
      card_text.apply({
        hasCta: has_cta ? 'yes' : 'no'
      })
      }}"
    >
      {% if heading_level == 2 %}
        <h2 class="text-xl font-medium">{{ heading_text }}</h2>
      {% elseif heading_level == 4 %}
        <h4 class="text-xl font-medium">{{ heading_text }}</h4>
      {% else %}
        <h3 class="text-xl font-medium">{{ heading_text }}</h3>
      {% endif %}

      {% if has_text %}
        <p class="mb-0 font-body text-base font-light">
          {{ text }}
        </p>
      {% endif %}
    </div>

    {% if has_cta %}
      <div class="pointer-events-auto">
        {{
          include(
            '@drupalorg/components/button/button.twig',
            {
              label: cta_text,
              href: url,
              variant: button_variant,
              icon: 'arrow-right'
            },
            with_context: false
          )
        }}
      </div>
    {% endif %}
  </div>
</div>
