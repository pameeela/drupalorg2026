{% set is_autoplay = autoplay|default(true) %}
{% set per_view = slides_per_view|default('1') %}

{% set carousel =
  html_cva(
    base: 'carousel cq-full flex flex-col gap-8',
    variants: {
      perView: {
        '1': 'carousel--per-view-1',
        '2': 'carousel--per-view-2',
        '3': 'carousel--per-view-3'
      }
    }
  )
%}

<section
  class="{{
  carousel.apply({
    perView: per_view
  })
  }}"
  data-autoplay="{{ is_autoplay ? 'true' : 'false' }}"
>
  {% if block('header') is defined %}
    <div class="carousel__header flex flex-col items-center gap-4 text-center">
      {% block header %}
        {% include '@drupalorg/components/badge/badge.twig' with {
          label: 'Why Drupal CMS',
          style: 'transparent'
        } only %}
        <h2>Launch professional websites in hours, not weeks.</h2>
      {% endblock %}
    </div>
  {% endif %}

  {# Feature nav row — populated by carousel.js from each slide's nav. #}
  <div class="carousel__nav" role="group" aria-label="{{ 'Carousel features'|t }}"></div>

  <div class="swiper">
    <div class="swiper-wrapper">
      {% block slides %}
        {% embed 'drupalorg:slide' with { title: 'One-click site templates', icon: 'squares-four', description: 'Choose a template, launch, and customise. Professional sites in hours.' } %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with { label: 'Template Library', href: '#', variant: 'primary', icon: 'arrow-right' } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}

        {% embed 'drupalorg:slide' with { title: 'AI agents from day one', icon: 'sparkle', description: 'Content creation, SEO, translation, accessibility — built in, not bolted on.' } %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with { label: 'Explore AI', href: '#', variant: 'primary', icon: 'arrow-right' } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}

        {% embed 'drupalorg:slide' with { title: 'No ceiling', icon: 'infinity', description: 'The same platform trusted by NASA, UNICEF, and the European Commission. Start small, scale infinitely.' } %}
          {% block content %}
            {% include '@drupalorg/components/button/button.twig' with { label: 'See what Drupal can do', href: '#', variant: 'primary', icon: 'arrow-right' } only %}
            <a href="#" class="text-sm font-medium text-dark-grey-400">Try Drupal Now</a>
          {% endblock %}
        {% endembed %}
      {% endblock %}
    </div>
  </div>

  {{ attach_library('drupalorg/carousel') }}
</section>
