{% set card =
  html_cva(
    base: ['flex h-full flex-col rounded-lg p-8 pt-20'],
    variants: {
      align: {
        center: 'items-center gap-6 text-center',
        left: 'items-start gap-4 text-left'
      },
      style: {
        light: 'bg-white shadow-lg',
        dark: 'bg-primary text-white'
      }
    }
  )
%}

{% set svg =
  html_cva(
    base: ['absolute'],
    variants: {
      style: {
        dark: '[filter:brightness(0)_invert(1)]'
      },
      align: {
        center: 'left-1/2',
        left: 'start-6'
      }
    }
  )
%}

{% set footer =
  html_cva(
    base: ['flex flex-row items-center gap-4 text-left text-base font-bold'],
    variants: {
      align: {
        center: 'justify-center',
        left: 'justify-start'
      }
    }
  )
%}

{% set svg_classes =
  svg.apply({
    style: style|default('default')
  })
%}

{% set card_classes =
  card.apply({
    align: align|default('center'),
    style: style|default('default')
  })
%}

{% set footer_classes =
  footer.apply({
    align: align|default('center')
  })
%}

<div class="{{ card_classes }} relative">
  <svg
    class="{{ svg_classes }} top-6 size-10"
    width="35"
    height="44"
    viewBox="0 0 35 44"
    fill="{{ resolved_svg_color }}"
    xmlns="http://www.w3.org/2000/svg"
  >
