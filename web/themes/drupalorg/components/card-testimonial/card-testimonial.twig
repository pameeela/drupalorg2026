      fill="#009CDE"
    />
  </svg>
  <blockquote class="relative z-10 flex grow flex-col gap-4" cite="{{ cite_url }}">
    <p class="grow text-xl text-inherit">
      {{ text }}
    </p>

    <footer class="{{ footer_classes }}">
      <div class="aspect-square w-[60px] overflow-hidden rounded-full">
        {% block media %}
          {% include 'canvas:image' ignore missing with {
            src: media.src,
            alt: media.alt,
            class: 'object-cover w-full h-full',
            width: media.width,
            height: media.height,
            sizes: '60px'
          } only %}
        {% endblock %}
      </div>
      <div>
        {% set citation = cite_name %}
        {{ citation }}
        <cite class="font-normal not-italic">
          <br />
          {% if cite_position %}
            <span class="text-base">{{ cite_position }}</span>
            <br />
          {% endif %}
          {% if cite_url %}
            <a href="{{ cite_url }}" target="_blank" class="underline underline-offset-2 hover:opacity-80">{{ cite_text }}</a>
          {% else %}
            <span class="text-base">{{ cite_text }}</span>
          {% endif %}
        </cite>
      </div>
    </footer>
  </blockquote>
</div>
