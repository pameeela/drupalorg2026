{# Normalize badge_classes - handle both array and string formats #}
{% set additional_classes = badge_classes|default('') %}
{% if additional_classes is iterable %}
  {% set additional_classes = additional_classes|join(' ') %}
{% endif %}

{% set badge =
  html_cva(
    base: ['rounded-sm border px-3 py-1.5', 'text-center text-[11px] leading-normal font-medium tracking-[0.55px] whitespace-nowrap uppercase'],
    variants: {
      style: {
        transparent: 'border-soft-grey-400 text-dark-grey-400',
        'transparent-inverse': 'border-dark-grey-100 text-white',
        white: 'border-soft-grey-400 bg-white text-dark-grey-500',
        dark: 'border-dark-grey-300 bg-dark-grey-400 text-soft-grey-300'
      }
    }
  )
%}

<span
  class="{{
  badge.apply(
    {
      style: style|default('transparent')
    },
    additional_classes
  )
  }}"
>
  {{ label }}
</span>
