{% set has_url = url is not empty %}
{% set has_media = media.src is not empty %}
{% set has_author = author_name is not empty or has_avatar %}

<article class="group relative flex h-full flex-col justify-end overflow-clip rounded-lg bg-dark-gray p-8 text-white">
  {% if has_media %}
    {# Hero image with a dark scrim for text legibility. #}
    <div class="absolute inset-0 transition duration-500 group-hover:scale-105">
      {% include 'canvas:image' ignore missing with {
        src: media.src,
        alt: media.alt,
        width: media.width,
        height: media.height,
        class: 'size-full object-cover'
      } only %}
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-darkest-gray/90 via-darkest-gray/50 to-transparent"></div>
  {% else %}
    <div class="absolute inset-0 bg-gradient-to-b from-dark-gray to-darkest-gray"></div>
  {% endif %}

  {% if has_url %}
    <a href="{{ url }}" class="absolute inset-0" aria-hidden="true" tabindex="-1"></a>
  {% endif %}

  <div class="pointer-events-none relative z-10 flex flex-col gap-6 text-sm font-semibold">
    <div class="flex flex-col gap-3">
      {% if date is not empty %}
        <p class="mb-0">
          {{ date|date('j F Y') }}
        </p>
      {% endif %}
      <h2 class="text-3xl font-semibold">{{ title }}</h2>
    </div>

    {% if has_author %}
      <div class="flex items-center gap-3">
        {% if author_name is not empty %}
          <span>{{ 'By'|t }} {{ author_name }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if has_url %}
      <div class="pointer-events-auto">
        {{
          include(
            '@drupalorg/components/button/button.twig',
            {
              label: cta_text|default('Read more'),
              href: url,
              variant: 'white',
              icon: 'arrow-right'
            },
            with_context: false
          )
        }}
      </div>
    {% endif %}
  </div>
</article>
