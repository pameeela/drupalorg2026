{% set has_url = url is not empty %}
{% set has_media = media.src is not empty %}
{% set has_author = author_name is not empty or has_avatar %}

<article class="relative flex min-h-[600px] flex-col justify-end overflow-clip rounded-lg bg-dark-grey-300 p-8 text-white">
  {% if has_media %}
    {# Hero image with a dark scrim for text legibility. #}
    <div class="absolute inset-0">
      {% include 'canvas:image' ignore missing with {
        src: media.src,
        alt: media.alt,
        width: media.width,
        height: media.height,
        class: 'size-full object-cover'
      } only %}
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-dark-grey-500/90 via-dark-grey-500/40 to-transparent"></div>
  {% else %}
    <div class="absolute inset-0 bg-gradient-to-b from-dark-grey-200 to-dark-grey-300"></div>
  {% endif %}

  <div class="relative flex flex-col gap-6">
    <div class="flex flex-col gap-3">
      {% if date is not empty %}
        <p class="mb-0 font-body text-sm font-light">
          {{ date|date('j F Y') }}
        </p>
      {% endif %}
      <h2 class="text-3xl font-semibold">{{ title }}</h2>
    </div>

    {% if has_author %}
      <div class="flex items-center gap-3">
        {% if author_name is not empty %}
          <span class="font-body text-sm">{{ 'By'|t }} {{ author_name }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if has_url %}
      {{
        include(
          '@drupalorg/components/button/button.twig',
          {
            label: cta_text|default('Read more'),
            href: url,
            variant: 'white',
            icon: 'arrow-right'
          },
          with_context: false
        )
      }}
    {% endif %}
  </div>
</article>
